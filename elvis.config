% -*- mode: erlang; -*- vim: set ft=erlang:
[
    {config, [
        #{
            files => ["src/**/*.erl"],
            ruleset => erl_files,
            rules => [
                % `decode_`/`encode_`-style trailing-underscore workers and the
                % underscore-prefixed `'_call'` common-test back door are an
                % intentional convention in this codebase.
                {elvis_style, function_naming_convention, #{
                    regex => "^_?[a-z](_?[a-z0-9]+)*_?(_test_)?$"
                }},
                % backwater is an RPC library: dispatching to arbitrary exposed
                % modules (`Module:module_info/0`, the target function) and to
                % `cowboy:start_clear/start_tls` is the whole point.
                {elvis_style, no_invalid_dynamic_calls, #{
                    ignore => [backwater, backwater_module_exposure]
                }},
                % req/0 (= cowboy_req:req/0) and friends are internal types used
                % only by the cowboy_handler behaviour callbacks; exporting them
                % would misrepresent them as part of the public API.
                {elvis_style, export_used_types, disable},
                % Most hits are the eunit suites embedded in these modules under
                % -ifdef(TEST) (elvis lints raw source, so it sees them); the few
                % in production code are deliberate parallel branch structures.
                {elvis_style, dont_repeat_yourself, disable}
            ]
        },
        #{
            files => ["test/**/*.erl"],
            ruleset => erl_files,
            rules => [
                {elvis_style, function_naming_convention, #{
                    regex => "^_?[a-z](_?[a-z0-9]+)*_?(_test_)?$"
                }},
                {elvis_style, dont_repeat_yourself, disable},
                {elvis_style, no_debug_call, disable},
                {elvis_style, no_invalid_dynamic_calls, disable},
                {elvis_style, no_if_expression, disable},
                {elvis_style, no_catch_expressions, disable},
                {elvis_style, no_used_ignored_variables, disable},
                {elvis_style, consistent_variable_naming, disable}
            ]
        },
        #{
            files => ["rebar.config", "elvis.config"],
            ruleset => rebar_config
        }
    ]}
].
